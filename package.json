    "@babel/parser": "^7.20.3",
    "@babel/traverse": "^7.20.1",
    "@types/commander": "^2.12.2",
    "@types/jasmine": "^4.3.0",
    "copy-webpack-plugin": "^11.0.0",
    "css-loader": "^6.7.2",
    "jasmine": "^4.5.0",
    "karma": "^6.4.1",
    "karma-chrome-launcher": "^3.1.1",
    "karma-jasmine": "^5.1.0",
    "karma-typescript": "^5.5.3",
    "sass": "^1.56.1",
    "sass-loader": "^13.2.0",
    "style-loader": "^3.3.1",
    "ts-loader": "^9.4.1",
    "typescript": "^4.8.4",
    "webpack": "^5.75.0",
    "webpack-cli": "^4.10.0",
    "webpack-dev-server": "^4.11.1"
  },
