{
  "name": "monster-js",
  "private": true,
  "version": "1.5.0",
  "main": "index.js",
  "license": "MIT",
  "workspaces": [
    "projects/*"
  ],
  "scripts": {
    "update-readme": "ncp ./packages/docs/docs/getting-started/what-is-monster-js.mdx ./README.md",
    "update-submodules": "git submodule update --recursive --remote",
    "build-all": "yarn workspace @monster-js/core build && yarn workspace @monster-js/router build && yarn workspace @monster-js/store build && yarn workspace @monster-js/tester build",
    "test": "yarn workspace @monster-js/test test"
  },
  "engines": {
    "node": "^14.15.0 || >=16.10.0"
  },
  "devDependencies": {
    "@babel/generator": "^7.20.14",
    "@babel/parser": "^7.20.7",
    "@babel/traverse": "^7.20.13",
    "@types/commander": "^2.12.2",
    "@types/jasmine": "^4.3.1",
    "@types/karma": "^6.3.3",
    "@types/ncp": "^2.0.5",
    "copy-webpack-plugin": "^11.0.0",
    "css-loader": "^6.7.3",
    "jasmine": "^4.5.0",
    "karma": "^6.4.1",
    "karma-chrome-launcher": "^3.1.1",
    "karma-jasmine": "^5.1.0",
    "karma-typescript": "^5.5.3",
    "ncp": "^2.0.0",
    "sass": "^1.57.1",
    "sass-loader": "^13.2.0",
    "style-loader": "^3.3.1",
    "ts-loader": "^9.4.2",
    "typescript": "^4.9.4",
    "webpack": "^5.75.0",
    "webpack-cli": "^5.0.1",
    "webpack-dev-server": "^4.11.1"
  },
  "dependencies": {
    "commander": "^10.0.0",
    "css-tree": "^2.3.1"
  }
}
