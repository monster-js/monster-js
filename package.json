{
  "name": "monster-js",
  "private": true,
  "version": "1.4.48",
  "main": "index.js",
  "license": "MIT",
  "workspaces": [
    "projects/*"
  ],
  "scripts": {
    "update-readme": "ncp ./packages/docs/docs/getting-started/what-is-monster-js.mdx ./README.md",
